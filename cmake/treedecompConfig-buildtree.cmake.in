# Config file for the Build-tree treedecomp package (not relocatable).
set(TREEDECOMP_INCLUDE_DIRS "@CMAKE_CURRENT_BINARY_DIR@/include")
include("${CMAKE_CURRENT_LIST_DIR}/treedecompTargets.cmake")
set(TREEDECOMP_LIBRARIES treedecomp)
set(TREEDECOMP_STATIC_LIBRARIES treedecomp)
set(TREEDECOMP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(TREEDECOMP_VERSION_MINOR @PROJECT_VERSION_MINOR@)
